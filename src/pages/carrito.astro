---
import Layout from "@layouts/Layout.astro";
import CarritoProducto from "@carrito/CarritoProducto.astro";
import CarritoLateral from "@carrito/CarritoLateral.astro";
import CarritoSuperior from "@components/Carrito/CarritoSuperior.astro";
import {fetchProductos} from "@utils/fetchProductos.ts";
import GeneralBotonPago from "@components/General/GeneralBotonPago.astro";
import GeneralBotonApple from "@components/General/GeneralBotonApple.astro";
import ProductoCarrusel from "@components/Producto/ProductoCarrusel.astro";
import ProductoTallas from "@components/Producto/ProductoTallas.astro";
import CarritoProductoContenedor from "@components/Carrito/CarritoProductoContenedor.astro";





let respuesta = await fetchProductos();
let arrayCategorias: any[] = respuesta.data.Categories;
let arrayTexto = respuesta.data.TickerTexts

let arrayProductos: any[] = respuesta.data.Products;








//console.log(arrayRecomendaciones);
---

<Layout arrayTexto={arrayTexto} mostrarTicker={true} botonIA={false} mostrarCarrito={false}>

<div>
  
  <div class="md:hidden fixed z-50 w-full bg-white bottom-0 p-4 py-2">
    <GeneralBotonApple></GeneralBotonApple>
    <a href="/checkout">
      <GeneralBotonPago texto="Confirmar pedido"></GeneralBotonPago>
    </a>
</div>

<div class="max-w-7xl mx-auto md:px-6">



  <div class="md:flex md:flex-col items-center col-span-8 min-w-4/5">
<div class="w-full">
  <CarritoSuperior cantidad="5"></CarritoSuperior>
</div>
    <div class="md:flex w-full grow">
      <!--izquierda-->

<div class="flex flex-col md:w-3/5 ml-0 sm:ml-6 md:ml-10 lg:ml-15">



  
    <CarritoProductoContenedor>
</CarritoProductoContenedor>

   
    <div class="hidden md:block">
      <ProductoCarrusel ArrayRecomendaciones={arrayProductos} />
    </div>
  </div>
  <!-- derecha -->
  <div class="md:w-2/5 px-5 mb-2">
    <CarritoLateral numeroProducto="4" precio="20" />

<div class="hidden md:block">
  <GeneralBotonApple></GeneralBotonApple>
  <a href="/checkout">
    <GeneralBotonPago texto="Confirmar pedido"></GeneralBotonPago>
  </a>
</div>
  </div>
</div>
  </div>


  </div>

</div>


      {arrayProductos.map((Valor: any) => (

  <ProductoTallas
      tallas={respuesta.data.Sizes[respuesta.data.Sizes.findIndex((e: any) => {
  return e.tag == Valor.tag;
})]}
      producto={Valor}
      price={Valor.price}
    />))}

  
  </Layout>
  
