>
<!-- 
 -->

  <div class="text-[rgb(127,89,59)] text-xs" x-show="producto.cantidadMaxima <= 5" x-text="'Quedan '+producto.cantidadMaxima"></div>
  <div class="flex justify-between">
    <div class="nombre"></div>
    <div class="precioValor" x-text="producto.cantidad*producto.precio+'€'"></div>
  </div>
  <div class="flex">
    <img
      class="imagen object-contain p-0 shrink-0 lozad"
      :src="producto.imagen + '?w=125&format=auto'"
      alt=""
      loading="lazy"
      
    />
    <div class="text-[rgb(82,82,82)] ml-2">
      <div class="text-sm color" x-text="'Color: '+producto.color"></div>
      <div class="text-sm talla" x-text="'Talla: '+producto.talla"></div>
      <div class="text-sm cantidadCheckout" x-show="pagina=='checkout'">Cantidad: </div>
    </div>
  </div>
  <div class="flex justify-between ml-2 mt-2" >

    <div class="*:border flex *:w-8 *:aspect-square *:border-[rgb(154,154,154)]" x-show="pagina=='carrito'">
  <button @click="if(producto.cantidad>1) producto.cantidad--" class="text-center">
    <span x-show="producto.cantidad != 1">-</span>
    <span x-show="producto.cantidad == 1" x-cloak class=" justify-center flex">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" id="trash" class="w-4 h-4 fill-current">
        <path fill-rule="evenodd" d="M13.83 6.68a1 1 0 0 1 .94-.68h2.46a1 1 0 0 1 .94.68L18.61 8H13.4l.44-1.32ZM11.98 10a.9.9 0 0 0 .04 0h7.96a.9.9 0 0 0 .04 0h2.9l-1.34 15.5H10.9L9.12 10h2.86Zm-.7-2 .65-1.95A3 3 0 0 1 14.77 4h2.46a3 3 0 0 1 2.84 2.05L20.72 8h4.78a1 1 0 1 1 0 2h-.58l-1.35 15.67a2 2 0 0 1-1.99 1.83H10.9a2 2 0 0 1-1.98-1.77L7.1 10h-.6a1 1 0 0 1 0-2h4.78ZM14 15a1 1 0 0 1 1 1v6.5a1 1 0 1 1-2 0V16a1 1 0 0 1 1-1Zm5 1a1 1 0 1 0-2 0v6.5a1 1 0 1 0 2 0V16Z" clip-rule="evenodd"/>
      </svg>
    </span>
  </button>
  <div x-text="producto.cantidad" class="flex justify-center items-center"/>
      <button @click="if (producto.cantidad<producto.cantidadMaxima) producto.cantidad++" 
      class="text-center"
      :class="producto.cantidad==producto.cantidadMaxima ? 'bg-[rgb(238,238,238)]' : ''"
      >+</button>
    </div>

  <div class="underline hover:cursor-pointer text-xs" x-show="pagina=='carrito'">Guardar para despues</div>
  </div>
  </div>

