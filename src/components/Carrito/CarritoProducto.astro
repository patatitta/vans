
<div class="carritoProducto p-5 flex flex-col border-b border-[rgb(225,225,225)] objetoProducto"
x-init="$watch('producto.cantidad', (valor, valorAntiguo) => { 
  const stored = localStorage.getItem('carrito');
  const carrito = JSON.parse(stored)
let encontrado= carrito.find((e) =>{
