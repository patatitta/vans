---
const { ArrayRecomendaciones } = Astro.props;

interface InterfazImagenes {
  url: string;
}

interface InterfazArrayRecomendaciones {
  name: String;
  price: Number;
  images: InterfazImagenes[];
  tag: string;
  id: string;
}
---

<script>
  import Swiper from "swiper";
import { Navigation } from 'swiper/modules';

  const prevEl = document.querySelector('#leftArrow');
      const nextEl = document.querySelector('#rightArrow');

  const swiper = new Swiper(".carruselProducto", {
              modules: [Navigation],
          navigation: {
            prevEl: prevEl as HTMLElement,
            nextEl: nextEl as HTMLElement,
          },
    slidesPerView: 1.2,
    spaceBetween: 16,
    breakpoints: {
      768: {
        slidesPerView: 6,
      },
    },
  });

  
</script>

<div class="flex justify-between items-center">
  <div class="ml-2 text-[rgb(38,36,36)]">También te aconsejamos</div>
  <div>
    <!-- Flecha izquierda -->
    <button aria-label="Imagen anterior" id="leftArrow"> 
      <svg
        class="w-6 h-6 rotate-180"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 32 32"
      >
        <path
          fill="currentColor"
          d="M9.91 24.96 19.37 16 9.9 7.04l1.5-1.58L22.54 16 11.41 26.54l-1.5-1.58Z"
        ></path>
      </svg>
    </button>

    <!-- Flecha derecha -->
    <button aria-label="Imagen siguiente" id="rightArrow">
      <svg
        class="w-6 h-6"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 32 32"
      >
        <path
          fill="currentColor"
          d="M9.91 24.96 19.37 16 9.9 7.04l1.5-1.58L22.54 16 11.41 26.54l-1.5-1.58Z"
        ></path>
      </svg>
    </button>
  </div>
</div>

<!-- Slider main container -->
<div class="swiper carruselProducto w-full h-full relative">
  <!-- Additional required wrapper -->
  <div class="swiper-wrapper w-full h-full relative">
    <!-- Slides -->
    {
      ArrayRecomendaciones.map((Valor: InterfazArrayRecomendaciones) => (
        <div class="relative swiper-slide">
          <div class=" aspect-4/5 ">
            <a href={Valor.tag + "-" + Valor.id}>
              <img
                class="w-full h-full p-1"
                src={`${Valor.images[0].url}?w=700`}
                alt="Mocasines 1"
                loading="lazy"
              />
            </a>
          </div>
          <div>
            <div class="text-center p-2 w-full wrap-break-word ">
              <>
                <div class="text-wrap wrap-break-word">{Valor.name}</div>
                <div class="text-xs text-neutral-500 text-wrap wrap-break-word">
                  {Valor.price}€
                </div>
              </>
            </div>

            <button class="absolute right-4 top-9 -translate-y-1/2 z z-20 cursor-pointer p-2 hover:bg-white hidden md:block">
              <svg
                class="w-6 h-6"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 32 32"
                id="close"
              >
                <path
                  xmlns="http://www.w3.org/2000/svg"
                  d="M17.1 5.9v9h9v2.2h-9v9h-2.2v-9h-9v-2.2h9v-9h2.2Z"
                />
              </svg>
            </button>
          </div>
        </div>
      ))
    }
  </div>
</div>
